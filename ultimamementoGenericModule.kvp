; Ultima Memento - AMP Generic Module Configuration
; An Ultima Online private server powered by the Memento project
;
; IMPORTANT: After changing settings in the AMP UI, click "Update" to
; regenerate Settings.override.cs and recompile the server, then restart.

; ============================================================
; Meta - Module identity and display
; ============================================================
Meta.DisplayName=Ultima Memento
Meta.Description=Ultima Online private server powered by Memento
Meta.OS=3
Meta.AppConfigId=47d92e91-73a5-4477-bbfd-711431a3394e
Meta.Author=Team7d0
Meta.URL=https://github.com/Jascen/ultima-memento
Meta.DisplayImageSource=url:https://raw.githubusercontent.com/Jascen/ultima-memento/main/World/Info/Art/logo.png
Meta.ConfigManifest=ultimamemento-configmanifest.json
Meta.MetaConfigManifest=ultimamemento-metaconfig.json
Meta.ConfigRoot=ultimamementoGenericModule.kvp
Meta.ContainerPolicy=SupportedOnLinux
Meta.ExtraContainerPackages=["git","mono-complete"]

; ============================================================
; Application - Runtime configuration
; ============================================================
App.DisplayName=Ultima Memento
App.RootDir=./
App.WorkingDir=ultima-memento
App.ExecutableWin=World/World.exe
App.ExecutableLinux=World/WorldLinux.exe
App.Compatibility=1
App.HasWriteableConsole=true
App.HasReadableConsole=true
App.AdminMethod=STDIO
App.ExitMethod=String
App.ExitString=shutdown
App.RapidStartup=false
App.ApplicationPort1=2593
App.MaxUsers=100
App.CommandLineArgs=
App.EnvironmentVariables={}
App.AppSettings={}

; ============================================================
; Update Sources - Git clone, generate override, compile
; ============================================================
App.UpdateSources=[{"UpdateStageName":"Deploy Helper Script","UpdateSourcePlatform":"Linux","UpdateSource":"Executable","UpdateSourceData":"/bin/bash","UpdateSourceArgs":"-c \"echo '' | base64 -d > ultimamemento-gensettings.sh && chmod +x ultimamemento-gensettings.sh\"","SkipOnFailure":true},{"UpdateStageName":"Clone or Update Repository","UpdateSourcePlatform":"Linux","UpdateSource":"Executable","UpdateSourceData":"/bin/bash","UpdateSourceArgs":"-c \"if [ -d ultima-memento/.git ]; then cd ultima-memento && git pull; else git clone https://github.com/Jascen/ultima-memento.git; fi\""},{"UpdateStageName":"Clone or Update Repository","UpdateSourcePlatform":"Windows","UpdateSource":"Executable","UpdateSourceData":"cmd.exe","UpdateSourceArgs":"/c \"if exist ultima-memento\\.git (cd ultima-memento && git pull) else (git clone https://github.com/Jascen/ultima-memento.git)\""},{"UpdateStageName":"Generate Settings Override","UpdateSourcePlatform":"Linux","UpdateSource":"Executable","UpdateSourceData":"/bin/bash","UpdateSourceArgs":"ultimamemento-gensettings.sh"},{"UpdateStageName":"Generate Settings Override","UpdateSourcePlatform":"Windows","UpdateSource":"Executable","UpdateSourceData":"powershell.exe","UpdateSourceArgs":"-ExecutionPolicy Bypass -File ultimamemento-gensettings.ps1"},{"UpdateStageName":"Set Compile Permissions","UpdateSourcePlatform":"Linux","UpdateSource":"SetExecutableFlag","UpdateSourceArgs":"ultima-memento/World/Source/Tools/compile-world-linux.sh"},{"UpdateStageName":"Compile Server","UpdateSourcePlatform":"Linux","UpdateSource":"Executable","UpdateSourceData":"/bin/bash","UpdateSourceArgs":"-c \"cd ultima-memento/World/Source/Tools && ./compile-world-linux.sh\""},{"UpdateStageName":"Compile Server","UpdateSourcePlatform":"Windows","UpdateSource":"Executable","UpdateSourceData":"cmd.exe","UpdateSourceArgs":"/c \"cd ultima-memento\\World\\Source\\Tools && compile-world-win.bat\""}]

; ============================================================
; Console - Regex patterns for server output parsing
; ============================================================
; NOTE: These regexes may need tuning based on actual server console output.
; Start the server once and observe the output to refine these patterns.
Console.AppReadyRegex=^.*(?:World Started|Server Started|Listening).*$
Console.ThrowawayMessageRegex=
Console.UserJoinRegex=^.*:\s+(?<username>.+?) has logged in\.$
Console.UserLeaveRegex=^.*:\s+(?<username>.+?) has logged out\.$
Console.UserChatRegex=
